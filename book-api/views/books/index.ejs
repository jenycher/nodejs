<%
title = 'Список книг';
%>

<div class="books-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <h2>Все книги (<%= books.length %>)</h2>
    <div>
        <a href="/" class="btn">🏠 Главная</a>
        <a href="/books/create" class="btn btn-success">+ Добавить книгу</a>
    </div>
</div>

<% if (books.length === 0) { %>
    <div class="alert alert-info">
        Пока нет ни одной книги. <a href="/books/create">Добавьте первую книгу!</a>
    </div>
<% } else { %>
    <div class="books-table-container">
        <table class="books-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Название книги</th>
                    <th>Автор(ы)</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                <% books.forEach((book, index) => { %>
                    <tr>
                        <td class="book-number"><%= index + 1 %></td>
                        <td class="book-title-cell">
                            <%= book.title %>
                            <% if (book.favorite) { %>
                                <span class="favorite-star">⭐</span>
                            <% } %>
                        </td>
                        <td class="book-authors-cell"><%= book.authors || '—' %></td>
                        <td class="book-actions-cell">
                            <a href="/books/<%= book.id %>" class="action-btn view-btn" title="Просмотр">
                                👁️
                            </a>
                            <a href="/books/<%= book.id %>/edit" class="action-btn edit-btn" title="Редактировать">
                                ✏️
                            </a>
                            <form action="/books/<%= book.id %>/delete" method="POST" style="display: inline;">
                                <button type="submit" class="action-btn delete-btn" title="Удалить" onclick="return confirm('Вы уверены, что хотите удалить книгу «<%= book.title %>»?')">
                                    🗑️
                                </button>
                            </form>
                            <% if (book.fileBook) { %>
                                <a href="/books/<%= book.id %>/download" class="action-btn download-btn" title="Скачать">
                                    📥
                                </a>
                            <% } %>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
<% } %>

<style>
    .books-table-container {
        background: white;
        border-radius: 8px;
        overflow-x: auto;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    
    .books-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.95rem;
    }
    
    .books-table thead {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }
    
    .books-table th {
        padding: 1rem;
        text-align: left;
        font-weight: 600;
    }
    
    .books-table td {
        padding: 1rem;
        border-bottom: 1px solid #e2e8f0;
        vertical-align: middle;
    }
    
    .books-table tbody tr:hover {
        background-color: #f7fafc;
        transition: background-color 0.2s;
    }
    
    .book-number {
        width: 60px;
        text-align: center;
        font-weight: 600;
        color: #4a5568;
        font-size: 1rem;
    }
    
    .book-title-cell {
        font-weight: 500;
        color: #2d3748;
    }
    
    .book-title-cell strong {
        font-size: 1rem;
    }
    
    .favorite-star {
        margin-left: 0.5rem;
        font-size: 0.9rem;
        display: inline-block;
        animation: starPulse 0.3s ease;
    }
    
    @keyframes starPulse {
        0% { transform: scale(0); }
        100% { transform: scale(1); }
    }
    
    .book-authors-cell {
        color: #4a5568;
    }
    
    .book-actions-cell {
        white-space: nowrap;
        text-align: center;
    }
    
    .action-btn {
        display: inline-block;
        padding: 0.4rem 0.6rem;
        margin: 0 0.2rem;
        text-decoration: none;
        font-size: 1.2rem;
        border-radius: 6px;
        transition: all 0.2s;
        cursor: pointer;
        border: none;
        background: none;
        font-family: monospace;
    }
    
    .action-btn:hover {
        transform: scale(1.1);
    }
    
    .view-btn {
        color: #4299e1;
    }
    
    .view-btn:hover {
        background-color: #ebf8ff;
        color: #2b6cb0;
    }
    
    .edit-btn {
        color: #48bb78;
    }
    
    .edit-btn:hover {
        background-color: #f0fff4;
        color: #2f855a;
    }
    
    .delete-btn {
        color: #f56565;
    }
    
    .delete-btn:hover {
        background-color: #fff5f5;
        color: #c53030;
    }
    
    .download-btn {
        color: #9f7aea;
    }
    
    .download-btn:hover {
        background-color: #faf5ff;
        color: #6b46c1;
    }
    
    @media (max-width: 768px) {
        .books-table th,
        .books-table td {
            padding: 0.75rem 0.5rem;
        }
        
        .book-number {
            width: 40px;
            font-size: 0.85rem;
        }
        
        .action-btn {
            padding: 0.3rem 0.4rem;
            font-size: 1rem;
        }
        
        .book-title-cell {
            max-width: 150px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        
        .book-authors-cell {
            max-width: 120px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
    }
    
    @media (max-width: 480px) {
        .book-number {
            width: 35px;
            font-size: 0.75rem;
        }
        
        .action-btn {
            padding: 0.25rem 0.3rem;
            font-size: 0.9rem;
            margin: 0 0.1rem;
        }
        
        .books-table th {
            font-size: 0.85rem;
        }
        
        .books-table td {
            font-size: 0.85rem;
        }
    }
</style>