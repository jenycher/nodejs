<%
title = book.title;
%>

<div class="book-view-container">
    <div class="book-view-header">
        <a href="/books" class="back-link">← Назад к списку</a>
        <div class="book-actions-top">
            <a href="/books/<%= book.id %>/edit" class="btn-edit">
                <span class="btn-icon">✏️</span>
                Редактировать
            </a>
            <form action="/books/<%= book.id %>/delete" method="POST" style="display: inline;">
                <button type="submit" class="btn-delete" onclick="return confirm('Вы уверены, что хотите удалить книгу «<%= book.title %>»?')">
                    <span class="btn-icon">🗑️</span>
                    Удалить
                </button>
            </form>
        </div>
    </div>
    
    <div class="book-view-content">
        <!-- Левая колонка - обложка и файл -->
        <div class="book-sidebar">
            <% if (book.fileCover) { %>
                <div class="cover-container">
                    <div class="cover-wrapper">
                        <img src="/public/img/<%= book.fileCover %>" alt="Обложка книги <%= book.title %>" class="book-cover">
                    </div>
                    <div class="cover-info">
                        <span class="cover-label">Обложка</span>
                        <span class="cover-filename"><%= decodeURIComponent(book.fileCover) %></span>
                    </div>
                </div>
            <% } else { %>
                <div class="no-cover">
                    <div class="no-cover-icon">📖</div>
                    <div class="no-cover-text">Обложка отсутствует</div>
                </div>
            <% } %>
            
            <% if (book.fileBook && fileInfo && fileInfo.exists) { %>
                <div class="book-file-card">
                    <div class="file-card-header">
                        <span class="file-icon">📄</span>
                        <span>Файл книги</span>
                    </div>
                    <div class="file-card-content">
                        <div class="file-type-badge">
                            <%= fileInfo.extension %>
                        </div>
                        <div class="file-details">
                            <div class="file-name">
                                <%= decodeURIComponent(book.fileName || book.fileBook) %>
                            </div>
                            <div class="file-meta">
                                <span class="file-size">📦 <%= fileInfo.size %></span>
                                <span class="file-date">📅 <%= fileInfo.date %></span>
                            </div>
                        </div>
                    </div>
                    <div class="file-card-actions">
                        <a href="/books/<%= book.id %>/download" class="btn-download">
                            <span class="btn-icon">📥</span>
                            Скачать книгу
                        </a>
                    </div>
                </div>
            <% } else if (book.fileBook && (!fileInfo || !fileInfo.exists)) { %>
                <div class="no-file-card">
                    <div class="no-file-icon">⚠️</div>
                    <div class="no-file-text">Файл книги не найден на сервере</div>
                </div>
            <% } else { %>
                <div class="no-file-card">
                    <div class="no-file-icon">📚</div>
                    <div class="no-file-text">Файл книги не загружен</div>
                </div>
            <% } %>
        </div>
        
        <!-- Правая колонка - информация о книге -->
        <div class="book-info">
            <div class="book-title-section">
                <h1 class="book-title"><%= book.title %></h1>
                <% if (book.favorite) { %>
                    <span class="favorite-badge">
                        <span class="favorite-star">⭐</span>
                        Избранное
                    </span>
                <% } %>
            </div>
            
            <div class="book-meta">
                <div class="meta-item">
                    <span class="meta-icon">✍️</span>
                    <span class="meta-label">Автор(ы):</span>
                    <span class="meta-value"><%= book.authors || 'Не указан' %></span>
                </div>
                <div class="meta-item">
                    <span class="meta-icon">📅</span>
                    <span class="meta-label">Добавлена:</span>
                    <span class="meta-value"><%= addedDate || 'Неизвестно' %></span>
                </div>
            </div>

            <!-- ============== НОВЫЙ БЛОК СЧЁТЧИКА ПРОСМОТРОВ ============== -->
            <div class="counter-card">
                <div class="counter-header">
                    <span class="counter-icon">👁️</span>
                    <span class="counter-title">Просмотры</span>
                </div>
                <div class="counter-value" id="counterValue">
                    <%= book.views !== undefined ? book.views : 0 %>
                </div>
                <div class="counter-footer">
                    <span class="counter-note">Каждый просмотр страницы увеличивает счётчик</span>
                </div>
            </div>
            <!-- ============== КОНЕЦ БЛОКА СЧЁТЧИКА ============== -->
            
            <% if (book.description) { %>
                <div class="book-description">
                    <h3>📝 Описание</h3>
                    <div class="description-content">
                        <%= book.description.replace(/\n/g, '<br>') %>
                    </div>
                </div>
            <% } else { %>
                <div class="no-description">
                    <span class="no-description-icon">📝</span>
                    <span>Описание отсутствует</span>
                </div>
            <% } %>
            
            <div class="book-stats">
                <div class="stat-item">
                    <span class="stat-icon">🔖</span>
                    <span class="stat-label">ID книги:</span>
                    <span class="stat-value stat-value-mono"><%= book.id %></span>
                    <button class="copy-id-btn" onclick="copyToClipboard('<%= book.id %>')" title="Скопировать ID">
                        📋
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function copyToClipboard(text) {
    navigator.clipboard.writeText(text).then(() => {
        // Показываем уведомление
        const btn = event.target;
        const originalText = btn.textContent;
        btn.textContent = '✅';
        setTimeout(() => {
            btn.textContent = originalText;
        }, 2000);
        
        // Создаем всплывающее уведомление
        const notification = document.createElement('div');
        notification.className = 'copy-notification';
        notification.textContent = 'ID скопирован!';
        document.body.appendChild(notification);
        
        setTimeout(() => {
            notification.remove();
        }, 2000);
    }).catch(err => {
        console.error('Ошибка копирования:', err);
        alert('Не удалось скопировать ID');
    });
}
</script>

