<%
title = 'Добавить новую книгу';
%>

<div class="create-book-container">
    <div class="create-book-header">
        <a href="/books" class="back-link">← Назад к списку</a>
        <h1>✨ Создать новую книгу</h1>
        <p class="header-description">Заполните информацию о книге и загрузите необходимые файлы</p>
    </div>
    
    <form action="/books" method="POST" enctype="multipart/form-data" class="create-book-form" id="createBookForm">
        <div class="form-grid">
            <!-- Левая колонка - основные поля -->
            <div class="form-main">
                <div class="form-section">
                    <h3>📖 Основная информация</h3>
                    
                    <div class="form-group">
                        <label for="title">
                            <span class="label-icon">📖</span>
                            Название книги
                            <span class="required">*</span>
                        </label>
                        <input type="text" id="title" name="title" required 
                               value="<%= formData ? formData.title : '' %>" 
                               placeholder="Введите название книги"
                               class="form-input"
                               autofocus>
                        <div class="field-hint">
                            <span class="hint-icon">ℹ️</span>
                            Обязательное поле. Название должно быть уникальным
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="authors">
                            <span class="label-icon">✍️</span>
                            Автор(ы)
                        </label>
                        <input type="text" id="authors" name="authors" 
                               value="<%= formData ? formData.authors : '' %>" 
                               placeholder="Например: Лев Толстой, Федор Достоевский"
                               class="form-input">
                        <div class="field-hint">
                            <span class="hint-icon">💡</span>
                            Если авторов несколько, укажите их через запятую
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="description">
                            <span class="label-icon">📝</span>
                            Описание
                        </label>
                        <textarea id="description" name="description" 
                                  placeholder="Введите описание книги. Расскажите о сюжете, главных героях, интересных фактах..."
                                  class="form-textarea"><%= formData ? formData.description : '' %></textarea>
                        <div class="field-hint">
                            <span class="hint-icon">📋</span>
                            Подробное описание поможет читателям лучше понять содержание книги
                        </div>
                    </div>
                    
                    <div class="form-group checkbox-group">
                        <label class="checkbox-label">
                            <input type="checkbox" name="favorite" value="true" <%= (formData && formData.favorite === 'true') ? 'checked' : '' %>>
                            <span class="checkbox-custom"></span>
                            <span class="checkbox-text">
                                <span class="label-icon">⭐</span>
                                Добавить в избранное
                            </span>
                        </label>
                        <div class="field-hint">
                            <span class="hint-icon">❤️</span>
                            Избранные книги будут отображаться с отметкой и могут быть выделены в списке
                        </div>
                    </div>
                </div>
                
                <!-- Бонус: подсказки для заполнения -->
                <div class="tips-section">
                    <div class="tips-header">
                        <span class="tips-icon">💡</span>
                        <span>Советы по заполнению</span>
                    </div>
                    <ul class="tips-list">
                        <li>Используйте полное название книги, включая подзаголовок, если он есть</li>
                        <li>Для авторов укажите фамилию и инициалы в общепринятом формате</li>
                        <li>В описании укажите жанр, год издания и основную идею книги</li>
                        <li>Загружайте файлы в популярных форматах для лучшей совместимости</li>
                    </ul>
                </div>
            </div>
            
            <!-- Правая колонка - файлы -->
            <div class="form-files">
                <div class="form-section">
                    <h3>🖼️ Обложка книги</h3>
                    
                    <div class="file-upload-area" id="coverUploadArea">
                        <label for="fileCover" class="file-upload-label">
                            <div class="upload-icon">📁</div>
                            <div class="upload-text">
                                <strong>Выберите обложку</strong>
                                <span>или перетащите файл сюда</span>
                            </div>
                            <input type="file" id="fileCover" name="fileCover" accept="image/*" class="file-input" onchange="previewCover(this)">
                        </label>
                        <div class="field-hint">
                            <span class="hint-icon">🖼️</span>
                            <strong>Допустимые форматы:</strong> JPEG, PNG, GIF, WEBP<br>
                            <strong>Рекомендуемый размер:</strong> до 2 MB
                        </div>
                    </div>
                    
                    <div id="coverPreview" class="cover-preview-area" style="display: none;">
                        <div class="preview-header">
                            <span class="preview-icon">✅</span>
                            <span>Предпросмотр обложки</span>
                            <button type="button" class="remove-file" onclick="removeCover()">✖</button>
                        </div>
                        <div class="preview-content">
                            <img id="coverPreviewImage" src="" alt="Предпросмотр обложки">
                            <div class="preview-info">
                                <div class="preview-filename" id="coverFilename"></div>
                                <div class="preview-filesize" id="coverFilesize"></div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="form-section">
                    <h3>📚 Файл книги</h3>
                    
                    <div class="file-upload-area" id="bookUploadArea">
                        <label for="fileBook" class="file-upload-label">
                            <div class="upload-icon">📂</div>
                            <div class="upload-text">
                                <strong>Выберите файл книги</strong>
                                <span>или перетащите файл сюда</span>
                            </div>
                            <input type="file" id="fileBook" name="fileBook" accept=".pdf,.doc,.docx,.txt,.fb2,.epub" class="file-input" onchange="previewBook(this)">
                        </label>
                        <div class="field-hint">
                            <span class="hint-icon">📄</span>
                            <strong>Допустимые форматы:</strong> PDF, DOC, DOCX, TXT, FB2, EPUB<br>
                            <strong>Максимальный размер:</strong> 50 MB
                        </div>
                    </div>
                    
                    <div id="bookPreview" class="file-preview-area" style="display: none;">
                        <div class="preview-header">
                            <span class="preview-icon">✅</span>
                            <span>Выбранный файл</span>
                            <button type="button" class="remove-file" onclick="removeBook()">✖</button>
                        </div>
                        <div class="preview-content file-preview">
                            <div class="file-type-icon" id="bookTypeIcon"></div>
                            <div class="preview-info">
                                <div class="preview-filename" id="bookFilename"></div>
                                <div class="preview-filesize" id="bookFilesize"></div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="info-box">
                    <div class="info-box-header">
                        <span class="info-icon">ℹ️</span>
                        <span>Важная информация</span>
                    </div>
                    <div class="info-box-content">
                        <p>После создания книги вы сможете:</p>
                        <ul>
                            <li>Редактировать информацию</li>
                            <li>Заменять файлы</li>
                            <li>Удалять книгу</li>
                            <li>Скачивать файлы</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="form-actions">
            <button type="submit" class="btn-submit" id="submitBtn">
                <span class="btn-icon">✨</span>
                Создать книгу
            </button>
            <button type="reset" class="btn-reset" onclick="resetForm()">
                <span class="btn-icon">🔄</span>
                Очистить форму
            </button>
            <a href="/books" class="btn-cancel">
                <span class="btn-icon">❌</span>
                Отмена
            </a>
        </div>
    </form>
</div>

<script>
    function previewCover(input) {
        const previewArea = document.getElementById('coverPreview');
        const uploadArea = document.getElementById('coverUploadArea');
        
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            const file = input.files[0];
            
            reader.onload = function(e) {
                document.getElementById('coverPreviewImage').src = e.target.result;
                document.getElementById('coverFilename').textContent = file.name;
                document.getElementById('coverFilesize').textContent = formatFileSize(file.size);
                
                previewArea.style.display = 'block';
                uploadArea.style.opacity = '0.6';
            }
            
            reader.readAsDataURL(file);
        }
    }
    
    function removeCover() {
        const coverInput = document.getElementById('fileCover');
        const previewArea = document.getElementById('coverPreview');
        const uploadArea = document.getElementById('coverUploadArea');
        
        coverInput.value = '';
        previewArea.style.display = 'none';
        uploadArea.style.opacity = '1';
    }
    
    function previewBook(input) {
        const previewArea = document.getElementById('bookPreview');
        const uploadArea = document.getElementById('bookUploadArea');
        
        if (input.files && input.files[0]) {
            const file = input.files[0];
            const fileExt = file.name.split('.').pop().toUpperCase();
            
            document.getElementById('bookFilename').textContent = file.name;
            document.getElementById('bookFilesize').textContent = formatFileSize(file.size);
            
            // Устанавливаем иконку в зависимости от типа файла
            const typeIcon = document.getElementById('bookTypeIcon');
            const iconMap = {
                'PDF': '📕',
                'DOC': '📘',
                'DOCX': '📘',
                'TXT': '📄',
                'FB2': '📗',
                'EPUB': '📙'
            };
            typeIcon.textContent = iconMap[fileExt] || '📚';
            
            previewArea.style.display = 'block';
            uploadArea.style.opacity = '0.6';
        }
    }
    
    function removeBook() {
        const bookInput = document.getElementById('fileBook');
        const previewArea = document.getElementById('bookPreview');
        const uploadArea = document.getElementById('bookUploadArea');
        
        bookInput.value = '';
        previewArea.style.display = 'none';
        uploadArea.style.opacity = '1';
    }
    
    function formatFileSize(bytes) {
        if (bytes === 0) return '0 Bytes';
        const k = 1024;
        const sizes = ['Bytes', 'KB', 'MB', 'GB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
    }
    
    function resetForm() {
        if (confirm('Вы уверены, что хотите очистить все поля?')) {
            document.getElementById('createBookForm').reset();
            removeCover();
            removeBook();
        }
    }
    
    // Drag and drop функциональность
    const coverDropZone = document.getElementById('coverUploadArea');
    const bookDropZone = document.getElementById('bookUploadArea');
    
    function setupDragAndDrop(dropZone, inputId, previewFunc) {
        ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
            dropZone.addEventListener(eventName, preventDefaults, false);
        });
        
        function preventDefaults(e) {
            e.preventDefault();
            e.stopPropagation();
        }
        
        ['dragenter', 'dragover'].forEach(eventName => {
            dropZone.addEventListener(eventName, highlight, false);
        });
        
        ['dragleave', 'drop'].forEach(eventName => {
            dropZone.addEventListener(eventName, unhighlight, false);
        });
        
        function highlight(e) {
            dropZone.classList.add('drag-over');
        }
        
        function unhighlight(e) {
            dropZone.classList.remove('drag-over');
        }
        
        dropZone.addEventListener('drop', handleDrop, false);
        
        function handleDrop(e) {
            const dt = e.dataTransfer;
            const files = dt.files;
            const fileInput = document.getElementById(inputId);
            
            fileInput.files = files;
            
            // Триггерим событие change для предпросмотра
            const event = new Event('change', { bubbles: true });
            fileInput.dispatchEvent(event);
            
            // Вызываем функцию предпросмотра
            if (previewFunc === 'cover') {
                previewCover(fileInput);
            } else if (previewFunc === 'book') {
                previewBook(fileInput);
            }
        }
    }
    
    setupDragAndDrop(coverDropZone, 'fileCover', 'cover');
    setupDragAndDrop(bookDropZone, 'fileBook', 'book');
    
    // Валидация формы перед отправкой
    document.getElementById('createBookForm').addEventListener('submit', function(e) {
        const title = document.getElementById('title').value.trim();
        
        if (!title) {
            e.preventDefault();
            alert('Пожалуйста, введите название книги');
            document.getElementById('title').focus();
            return false;
        }
        
        // Показываем индикатор загрузки
        const submitBtn = document.getElementById('submitBtn');
        submitBtn.innerHTML = '<span class="btn-icon">⏳</span> Создание...';
        submitBtn.disabled = true;
        
        return true;
    });
</script>

